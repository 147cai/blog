---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import TOC from "../components/widget/TOC.astro";
import { bannerImages, bannerText, siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import { url } from "../utils/url-utils";
import Layout from "./Layout.astro";

// 轮播图片列表：优先用 bannerImages，否则回退到单张 banner.src
const bannerList =
	bannerImages.length > 0 ? bannerImages : [siteConfig.banner.src];
const bannerCycle = bannerList.length * 6; // 每张展示 6s，总循环时长

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-0 md:px-4 mx-auto" class:list={[""]}>
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar></Navbar>
    </div>
</div>

<!-- Banner -->
{siteConfig.banner.enable && <div id="banner-wrapper" class={`absolute z-10 w-full transition duration-700 overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <div id="banner" class="h-full transition duration-700 opacity-0 scale-105 relative overflow-hidden">
        <!-- 多图轮播 + 缓慢放大（Ken Burns），仿旧 shoka 主题 -->
        <div class="banner-carousel absolute inset-0 w-full h-full bg-black">
            {bannerList.map((src, i) => (
                <div class="banner-slide absolute inset-0 w-full h-full bg-cover bg-center"
                     style={`background-image: url('${url(src)}'); animation-delay: ${i * 6}s; animation-duration: ${bannerCycle}s;`}>
                </div>
            ))}
        </div>
        <!-- 顶部渐变：让透明导航栏的文字在亮色头图上也清晰 -->
        <div class="banner-top-gradient absolute top-0 left-0 w-full h-28 pointer-events-none z-10"></div>
        <!-- 头图居中标题文字（仿 shoka，文字在 config.ts 的 bannerText 里编辑） -->
        {bannerText.enable && (
            <div class="banner-title absolute inset-0 z-20 flex flex-col items-center justify-center text-center px-4 pointer-events-none">
                {bannerText.titleEn && <p class="banner-title-en">{bannerText.titleEn}</p>}
                {bannerText.title && <h1 class="banner-title-main">{bannerText.title}</h1>}
                {bannerText.subtitle && <p class="banner-title-sub">= {bannerText.subtitle} =</p>}
            </div>
        )}
    </div>
    <!-- 动态波浪分隔（4 层不同透明度横向平移，仿 shoka） -->
    <div class="banner-waves absolute left-0 w-full pointer-events-none z-20">
        <svg class="waves-svg" viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
            <defs>
                <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z" />
            </defs>
            <g class="wave-parallax">
                <use href="#gentle-wave" x="48" y="0" />
                <use href="#gentle-wave" x="48" y="3" />
                <use href="#gentle-wave" x="48" y="5" />
                <use href="#gentle-wave" x="48" y="7" />
            </g>
        </svg>
    </div>
</div>}

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <!-- The pointer-events-none here prevent blocking the click event of the TOC -->
    <div class="relative max-w-[var(--page-width)] mx-auto pointer-events-auto">
        <div id="main-grid" class="transition duration-700 w-full left-0 right-0 grid grid-cols-[17.5rem_auto] grid-rows-[auto_1fr_auto] lg:grid-rows-[auto]
    mx-auto gap-4 px-0 md:px-4"
        >
            <!-- Banner image credit -->
            {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                   class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
                                   "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
            >
                <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                <Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
                    {"group-hover:opacity-100": hasBannerLink}]}
                      name="fa6-solid:arrow-up-right-from-square">
                </Icon>
            </a>}


            <SideBar class="mb-4 row-start-2 row-end-3 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[17.5rem] onload-animation" headings={headings}></SideBar>

            <main id="swup-container" class="transition-swup-fade col-span-2 lg:col-span-1 overflow-hidden">
                <div id="content-wrapper" class="onload-animation">
                    <!-- the overflow-hidden here prevent long text break the layout-->
                    <!-- make id different from windows.swup global property -->
                    <slot></slot>
                    <div class="footer col-span-2 onload-animation hidden lg:block">
                        <Footer></Footer>
                    </div>
                </div>
            </main>

            <div class="footer col-span-2 onload-animation block lg:hidden">
                <Footer></Footer>
            </div>
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<!-- The things that should be under the banner, only the TOC for now -->
<div class="absolute w-full z-0 hidden 2xl:block">
    <div class="relative max-w-[var(--page-width)] mx-auto">
        <!-- TOC component -->
        {siteConfig.toc.enable && <div id="toc-wrapper" class:list={["hidden lg:block transition absolute top-0 -right-[var(--toc-width)] w-[var(--toc-width)] items-center",
            {"toc-hide": siteConfig.banner.enable}]}
        >
            <div id="toc-inner-wrapper" class="fixed top-14 w-[var(--toc-width)] h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                <div id="toc" class="w-full h-full transition-swup-fade ">
                    <div class="h-8 w-full"></div>
                    <TOC headings={headings}></TOC>
                    <div class="h-8 w-full"></div>
                </div>
            </div>
        </div>}

        <!-- #toc needs to exist for Swup to work normally -->
        {!siteConfig.toc.enable && <div id="toc"></div>}
    </div>
</div>
</Layout>

<style>
/* ===== 头图轮播 + 缓慢放大（Ken Burns），仿旧 shoka 主题 ===== */
.banner-slide {
    opacity: 0;
    animation-name: bannerKenBurns;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    backface-visibility: hidden;
    transform-style: preserve-3d;
}
@keyframes bannerKenBurns {
    0%   { opacity: 0; transform: scale(1);    animation-timing-function: ease-in; }
    2%   { opacity: 1; }
    8%   { opacity: 1; transform: scale(1.05); animation-timing-function: ease-out; }
    17%  { opacity: 1; transform: scale(1.1); }
    25%  { opacity: 0; transform: scale(1.1); }
    100% { opacity: 0; }
}

/* 顶部渐变，提升透明导航栏文字可读性 */
.banner-top-gradient {
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.28), rgba(0, 0, 0, 0));
}

/* ===== 头图居中标题文字（仿 shoka） ===== */
.banner-title {
    /* 整体上移，居中于头图可见区，避开底部波浪与正文叠压区 */
    padding-bottom: 16vh;
    color: #fff;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.55), 0 1px 2px rgba(0, 0, 0, 0.45), 0 0 18px rgba(0, 0, 0, 0.25);
}
/* 标题后方柔和的深色径向光晕，保证在亮色头图上也有足够对比（非硬框） */
.banner-title::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 55% 42% at center 42%, rgba(0, 0, 0, 0.34), rgba(0, 0, 0, 0) 70%);
    pointer-events: none;
    z-index: -1;
}
.banner-title-en {
    font-family: Georgia, "Times New Roman", "Noto Serif SC", "Songti SC", serif;
    font-size: clamp(1.75rem, 3.6vw, 3rem);
    line-height: 1.15;
    letter-spacing: 0.08em;
    /* 玻璃质感：半透明填充让头图从字里透出，白色描边勾边，深色光晕保证在亮图上也可读 */
    color: rgba(255, 255, 255, 0.22);
    -webkit-text-stroke: 1.2px rgba(255, 255, 255, 0.95);
    text-shadow: 0 0 3px rgba(0, 0, 0, 0.55), 0 2px 6px rgba(0, 0, 0, 0.5), 0 0 22px rgba(0, 0, 0, 0.3);
}
.banner-title-main {
    font-size: clamp(1.5rem, 3.4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.3;
    margin-top: 0.4rem;
}
.banner-title-sub {
    font-size: clamp(0.8rem, 1.4vw, 1.05rem);
    letter-spacing: 0.14em;
    margin-top: 0.9rem;
    opacity: 0.95;
}
@media (max-width: 768px) {
    .banner-title { padding-bottom: 12vh; }
    .banner-title-sub { letter-spacing: 0.08em; }
}

/* ===== 动态波浪分隔 ===== */
.banner-waves {
    /* 贴住头图底边：波浪的实色填充一直盖到 banner 最底部，避免波浪与正文之间露出头图 */
    bottom: 0;
    line-height: 0;
}
.waves-svg {
    display: block;
    width: 100%;
    height: 11vh;
    min-height: 48px;
    max-height: 110px;
}
.wave-parallax > use {
    animation: waveMove 25s cubic-bezier(0.55, 0.5, 0.45, 0.5) infinite;
    fill: var(--page-bg);
}
.wave-parallax > use:nth-child(1) { animation-delay: -2s; animation-duration: 7s;  opacity: 0.7; }
.wave-parallax > use:nth-child(2) { animation-delay: -3s; animation-duration: 10s; opacity: 0.5; }
.wave-parallax > use:nth-child(3) { animation-delay: -4s; animation-duration: 13s; opacity: 0.3; }
.wave-parallax > use:nth-child(4) { animation-delay: -5s; animation-duration: 20s; opacity: 1;   }
@keyframes waveMove {
    0%   { transform: translate3d(-90px, 0, 0); }
    100% { transform: translate3d(85px, 0, 0); }
}

@media (max-width: 768px) {
    .waves-svg { height: 8vh; }
}
</style>
