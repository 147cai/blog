---
import MusicPlayer from "../components/MusicPlayer.svelte";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const pageTitle = "歌单";
const pageDesc = "偶尔听听歌，放松一下";

// 歌单列表（在这里增删/改 id 即可）。server: netease=网易云, tencent=QQ音乐；id 为歌单 ID
const playlists = [
	{ name: "2021年度歌单", server: "netease", type: "playlist", id: "7192693569" },
	{ name: "❤️网易云love", server: "netease", type: "playlist", id: "6675897026" },
	{ name: "❤️QQ音乐love", server: "tencent", type: "playlist", id: "2642086458" },
	{ name: "轻音乐", server: "tencent", type: "playlist", id: "7074303802" },
];
---

<MainGridLayout title={pageTitle} description={pageDesc}>
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<h1 class="text-3xl font-bold text-90 mb-1">🌸 偶尔听听歌</h1>
			<p class="text-50 mb-6">我的纯音乐还不错，来放松一下吧～</p>

			<MusicPlayer playlists={playlists} client:only="svelte" />
		</div>
	</div>
</MainGridLayout>
